# Font Awesome Pro (get your token from https://fontawesome.com/account#pro-package-tokens)
FONTAWESOME_PACKAGE_TOKEN=your-pro-package-token-here

# Formspree endpoint for contact form (create a form at https://formspree.io, set notification email to contact@fluemingo-app.com)
NUXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
